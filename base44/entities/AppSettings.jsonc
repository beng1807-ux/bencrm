    },
    "bit_barcode_url": {
      "type": "string",
      "description": "URL \u05dc\u05ea\u05de\u05d5\u05e0\u05ea \u05d1\u05e8\u05e7\u05d5\u05d3 \u05d1\u05d9\u05d8 \u05dc\u05ea\u05e9\u05dc\u05d5\u05dd"
    },
