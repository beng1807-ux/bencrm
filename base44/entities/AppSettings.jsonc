      "description": "\u05e7\u05d5\u05d1\u05e5 PDF \u05e9\u05d9\u05e6\u05d5\u05e8\u05e3 \u05dc\u05d4\u05d5\u05d3\u05e2\u05ea \u05e4\u05ea\u05d9\u05d7\u05d4 \u05dc\u05dc\u05d9\u05d3 \u05d7\u05d3\u05e9"
    },
    "dashboard_greeting": {
      "type": "string",
      "default": "\u05d4\u05d9\u05d9 {name}, \u05de\u05d4 \u05e7\u05d5\u05e8\u05d4 \u05d4\u05d9\u05d5\u05dd?"
