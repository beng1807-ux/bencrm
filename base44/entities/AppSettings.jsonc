    "payment_reminder_1_days_after_event": {
      "type": "number",
      "default": 1,
      "description": "\u05db\u05de\u05d4 \u05d9\u05de\u05d9\u05dd \u05d0\u05d7\u05e8\u05d9 \u05d1\u05d9\u05e6\u05d5\u05e2 \u05d4\u05d0\u05d9\u05e8\u05d5\u05e2 \u05dc\u05e9\u05dc\u05d5\u05d7 \u05ea\u05d6\u05db\u05d5\u05e8\u05ea \u05ea\u05e9\u05dc\u05d5\u05dd \u05e8\u05d0\u05e9\u05d5\u05e0\u05d4"
    },
    "payment_reminder_2_days_after_first": {
      "type": "number",
      "default": 2,
      "description": "\u05db\u05de\u05d4 \u05d9\u05de\u05d9\u05dd \u05d0\u05d7\u05e8\u05d9 \u05d4\u05ea\u05d6\u05db\u05d5\u05e8\u05ea \u05d4\u05e8\u05d0\u05e9\u05d5\u05e0\u05d4 \u05dc\u05e9\u05dc\u05d5\u05d7 \u05ea\u05d6\u05db\u05d5\u05e8\u05ea \u05e9\u05e0\u05d9\u05d9\u05d4"
    },
