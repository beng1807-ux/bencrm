    },
    "signature_text": {
      "type": "string",
      "default": "\u05e7\u05d1\u05d5\u05e6\u05ea \u05e1\u05e7\u05d9\u05e6\u05d4",
      "description": "\u05d7\u05ea\u05d9\u05de\u05d4 \u05e9\u05ea\u05d5\u05e4\u05d9\u05e2 \u05d1\u05e1\u05d5\u05e3 \u05db\u05dc \u05d4\u05d5\u05d3\u05e2\u05d4 \u05d1\u05de\u05e7\u05d5\u05dd \u05e9\u05dd \u05d4\u05d1\u05e2\u05dc\u05d9\u05dd"
    },
