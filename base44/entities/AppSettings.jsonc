      "default": "\u05dc\u05d5\u05d2 \u05d1\u05dc\u05d1\u05d3"
    },
    "whatsapp_test_phone": {
      "type": "string",
      "description": "\u05de\u05e1\u05e4\u05e8 \u05dc\u05e9\u05dc\u05d9\u05d7\u05ea \u05d1\u05d3\u05d9\u05e7\u05ea WhatsApp \u05d9\u05d7\u05d9\u05d3\u05d4"
    },
    "whatsapp_test_message": {
      "type": "string",
      "default": "\ud83d\udd14 \u05d4\u05d5\u05d3\u05e2\u05ea \u05d1\u05d3\u05d9\u05e7\u05d4 \u05de\u05e1\u05e7\u05d9\u05e6\u05d4 \u2014 \u05d0\u05dd \u05e7\u05d9\u05d1\u05dc\u05ea\u05dd \u05d0\u05ea \u05d4\u05d4\u05d5\u05d3\u05e2\u05d4, \u05d4\u05d7\u05d9\u05d1\u05d5\u05e8 \u05dc\u05d5\u05d5\u05e6\u05d0\u05e4 \u05ea\u05e7\u05d9\u05df.",
      "description": "\u05d8\u05e7\u05e1\u05d8 \u05d4\u05d5\u05d3\u05e2\u05ea \u05d1\u05d3\u05d9\u05e7\u05ea WhatsApp"
    },
    "whatsapp_retry_minutes": {
      "type": "number",
      "default": 5
    },
    "whatsapp_retry_max_attempts": {
      "type": "number",
      "default": 2
    },
    "quote_pdf_logo": {
      "type": "string"
    },
