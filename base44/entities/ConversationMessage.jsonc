{
  "type": "object",
  "properties": {
    "contact_id": {
      "type": "string",
      "description": "\u05de\u05d6\u05d4\u05d4 \u05d0\u05d9\u05e9 \u05e7\u05e9\u05e8"
    },
    "event_id": {
      "type": "string",
      "description": "\u05de\u05d6\u05d4\u05d4 \u05d0\u05d9\u05e8\u05d5\u05e2"
    },
    "channel": {
      "type": "string",
      "enum": [
        "WHATSAPP",
        "MANUAL",
        "SYSTEM"
      ],
      "default": "MANUAL",
      "description": "\u05e2\u05e8\u05d5\u05e5 \u05d4\u05ea\u05e7\u05e9\u05d5\u05e8\u05ea"
    },
    "sender": {
      "type": "string",
      "enum": [
        "OWNER",
        "CUSTOMER",
        "SYSTEM"
      ],
      "description": "\u05e9\u05d5\u05dc\u05d7 \u05d4\u05d4\u05d5\u05d3\u05e2\u05d4"
    },
    "message_text": {
      "type": "string",
      "description": "\u05ea\u05d5\u05db\u05df \u05d4\u05d4\u05d5\u05d3\u05e2\u05d4"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "\u05d6\u05de\u05df \u05d4\u05e9\u05dc\u05d9\u05d7\u05d4"
    },
    "attachments": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "\u05e7\u05d1\u05e6\u05d9\u05dd \u05de\u05e6\u05d5\u05e8\u05e4\u05d9\u05dd"
    }
  },
  "required": [
    "contact_id"
  ],
  "name": "ConversationMessage",
  "rls": {
    "create": {
      "user_condition": {
        "role": "admin"
      }
    },
    "read": {
      "user_condition": {
        "role": "admin"
      }
    },
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    },
