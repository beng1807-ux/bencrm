  "whatsapp_greeting": "\u05e9\u05dc\u05d5\u05dd! \ud83d\udc4b \u05d0\u05e0\u05d9 \u05d4\u05e1\u05d5\u05db\u05df \u05e9\u05dc \u05e1\u05e7\u05d9\u05e6\u05d4 \u05d4\u05e4\u05e7\u05d5\u05ea. \u05d0\u05e0\u05d9 \u05d9\u05db\u05d5\u05dc \u05dc\u05e2\u05d6\u05d5\u05e8 \u05dc\u05da \u05dc\u05e0\u05d4\u05dc \u05d0\u05ea \u05d4-CRM \u2014 \u05dc\u05e9\u05d0\u05d5\u05dc \u05e2\u05dc \u05d0\u05d9\u05e8\u05d5\u05e2\u05d9\u05dd, \u05ea\u05e7\u05dc\u05d9\u05d8\u05e0\u05d9\u05dd, \u05d0\u05e0\u05e9\u05d9 \u05e7\u05e9\u05e8, \u05de\u05e9\u05d9\u05de\u05d5\u05ea \u05d5\u05e2\u05d5\u05d3. \u05de\u05d4 \u05ea\u05e8\u05e6\u05d4 \u05dc\u05e2\u05e9\u05d5\u05ea?",
  "name": "skitza_crm"
